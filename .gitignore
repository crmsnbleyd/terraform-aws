# --- Terraform / OpenTofu ---
# Local .terraform directory (contains providers and modules)
.terraform/

# Distributed lock files
.terraform.lock.hcl

# State files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variables files (Avoid committing secrets)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# --- Python ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environments
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
dist/
build/
*.egg-info/

# Unit test / coverage reports
.pytest_cache/
.coverage
htmlcov/

# --- IDEs & OS ---
.vscode/
.idea/
.DS_Store
*.swp
*~
